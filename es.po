msgstr "Ejemplos: zeroclaw cron list zeroclaw cron add '0 9 * * 1-5' 'Buenos días' --tz America/New_York --agent zeroclaw cron add '\\*/30 * * * _' 'Comprobar la salud del sistema' --agent zeroclaw cron add '_/5 * * * \\*' 'echo ok' zeroclaw cron add-at 2025-01-15T14:00:00Z 'Enviar recordatorio' --agent zeroclaw cron add-every 60000 'Ping heartbeat' zeroclaw cron once 30m 'Ejecutar copia de seguridad en 30 minutos' --agent zeroclaw cron pause TASK_ID zeroclaw cron update TASK_ID --expression '0 8 * * \\*' --tz Europe/London"

